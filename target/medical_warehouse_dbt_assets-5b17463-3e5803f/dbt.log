{"data": {"conn_name": "model.medical_warehouse.stg_cleaned_messages", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "b557719d7f00166e92b565e34ccf84ff40b146b6c63ac7fcfebc1471b2207169", "node_finished_at": "", "node_name": "stg_cleaned_messages", "node_path": "staging\\stg_cleaned_messages.sql", "node_relation": {"alias": "stg_cleaned_messages", "database": "medical_warehouse", "relation_name": "\"medical_warehouse\".\"public\".\"stg_cleaned_messages\"", "schema": "public"}, "node_started_at": "2026-06-30T20:19:51.775482", "node_status": "executing", "resource_type": "model", "unique_id": "model.medical_warehouse.stg_cleaned_messages"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.stg_cleaned_messages\"} */\n\n  create view \"medical_warehouse\".\"public\".\"stg_cleaned_messages__dbt_tmp\"\n    \n    \n  as (\n    \n\nwith raw_staging as (\n    select * from \"medical_warehouse\".\"public\".\"stg_telegram_messages\"\n)\n\nselect\n    message_id,\n    channel_name,\n    message_date,\n    message_text,\n    views,\n    forwards,\n    has_media,\n    -- Add safe text-length and word-count processing for NLP downstream tasks\n    length(message_text) as character_count,\n    array_length(regexp_split_to_array(trim(message_text), '\\s+'), 1) as word_count\nfrom raw_staging\n-- Clean out empty updates or noise\nwhere message_text is not null \n  and length(trim(message_text)) > 0\n  );"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "942a75ef-8dd8-4303-80a4-35c171aa9580", "level": "debug", "msg": "On model.medical_warehouse.stg_cleaned_messages: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.stg_cleaned_messages\"} */\n\n  create view \"medical_warehouse\".\"public\".\"stg_cleaned_messages__dbt_tmp\"\n    \n    \n  as (\n    \n\nwith raw_staging as (\n    select * from \"medical_warehouse\".\"public\".\"stg_telegram_messages\"\n)\n\nselect\n    message_id,\n    channel_name,\n    message_date,\n    message_text,\n    views,\n    forwards,\n    has_media,\n    -- Add safe text-length and word-count processing for NLP downstream tasks\n    length(message_text) as character_count,\n    array_length(regexp_split_to_array(trim(message_text), '\\s+'), 1) as word_count\nfrom raw_staging\n-- Clean out empty updates or noise\nwhere message_text is not null \n  and length(trim(message_text)) > 0\n  );", "name": "SQLQuery", "pid": 14892, "thread": "Thread-5 (worker)", "ts": "2026-06-30T20:19:51.910005Z"}}
