{"data": {"conn_name": "model.medical_warehouse.fct_channel_engagement", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "0bd583a50dcfd26bce1bcfcea61a243e4bc1ca22a831131d4c4d9fb6cfbe260c", "node_finished_at": "", "node_name": "fct_channel_engagement", "node_path": "marts\\fct_channel_engagement.sql", "node_relation": {"alias": "fct_channel_engagement", "database": "medical_warehouse", "relation_name": "\"medical_warehouse\".\"public\".\"fct_channel_engagement\"", "schema": "public"}, "node_started_at": "2026-06-30T20:19:51.771634", "node_status": "executing", "resource_type": "model", "unique_id": "model.medical_warehouse.fct_channel_engagement"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.fct_channel_engagement\"} */\n\n  \n    \n\n  create  table \"medical_warehouse\".\"public\".\"fct_channel_engagement__dbt_tmp\"\n  \n  \n    as\n  \n  (\n    \n\nwith staging_data as (\n    select\n        channel_name,\n        message_id,\n        message_date,\n        message_length,\n        views,\n        forwards,\n        has_media\n    from \"medical_warehouse\".\"public\".\"stg_telegram_messages\"\n)\n\nselect\n    channel_name,\n    count(message_id) as total_messages,\n    sum(views) as total_views,\n    sum(forwards) as total_forwards,\n    -- Calculate averages safely\n    round(avg(views), 2) as avg_views_per_post,\n    round(avg(forwards), 2) as avg_forwards_per_post,\n    -- Count how many messages included images/media\n    sum(case when has_media = 1 then 1 else 0 end) as total_media_messages\nfrom staging_data\ngroup by channel_name\n  );\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "942a75ef-8dd8-4303-80a4-35c171aa9580", "level": "debug", "msg": "On model.medical_warehouse.fct_channel_engagement: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.fct_channel_engagement\"} */\n\n  \n    \n\n  create  table \"medical_warehouse\".\"public\".\"fct_channel_engagement__dbt_tmp\"\n  \n  \n    as\n  \n  (\n    \n\nwith staging_data as (\n    select\n        channel_name,\n        message_id,\n        message_date,\n        message_length,\n        views,\n        forwards,\n        has_media\n    from \"medical_warehouse\".\"public\".\"stg_telegram_messages\"\n)\n\nselect\n    channel_name,\n    count(message_id) as total_messages,\n    sum(views) as total_views,\n    sum(forwards) as total_forwards,\n    -- Calculate averages safely\n    round(avg(views), 2) as avg_views_per_post,\n    round(avg(forwards), 2) as avg_forwards_per_post,\n    -- Count how many messages included images/media\n    sum(case when has_media = 1 then 1 else 0 end) as total_media_messages\nfrom staging_data\ngroup by channel_name\n  );\n  ", "name": "SQLQuery", "pid": 14892, "thread": "Thread-8 (worker)", "ts": "2026-06-30T20:19:52.352727Z"}}
