{"data": {"conn_name": "model.medical_warehouse.fct_messages", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "01ca855e49658b559eb28adb005bf909235ddad6fb725719ca2d68e914d5e228", "node_finished_at": "", "node_name": "fct_messages", "node_path": "marts\\fct_messages.sql", "node_relation": {"alias": "fct_messages", "database": "medical_warehouse", "relation_name": "\"medical_warehouse\".\"public\".\"fct_messages\"", "schema": "public"}, "node_started_at": "2026-06-30T20:19:52.730178", "node_status": "executing", "resource_type": "model", "unique_id": "model.medical_warehouse.fct_messages"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.fct_messages\"} */\n\n  \n    \n\n  create  table \"medical_warehouse\".\"public\".\"fct_messages__dbt_tmp\"\n  \n  \n    as\n  \n  (\n    \n\nwith messages as (\n    select * from \"medical_warehouse\".\"public\".\"stg_cleaned_messages\"\n),\nchannels as (\n    select * from \"medical_warehouse\".\"public\".\"dim_channels\"\n)\n\nselect\n    m.message_id as message_key,\n    c.channel_key,\n    cast(to_char(m.message_date, 'YYYYMMDD') as integer) as date_key,\n    m.views,\n    m.forwards,\n    m.character_count,\n    m.word_count,\n    m.has_media\nfrom messages m\njoin channels c on m.channel_name = c.channel_name\n  );\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "942a75ef-8dd8-4303-80a4-35c171aa9580", "level": "debug", "msg": "On model.medical_warehouse.fct_messages: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.fct_messages\"} */\n\n  \n    \n\n  create  table \"medical_warehouse\".\"public\".\"fct_messages__dbt_tmp\"\n  \n  \n    as\n  \n  (\n    \n\nwith messages as (\n    select * from \"medical_warehouse\".\"public\".\"stg_cleaned_messages\"\n),\nchannels as (\n    select * from \"medical_warehouse\".\"public\".\"dim_channels\"\n)\n\nselect\n    m.message_id as message_key,\n    c.channel_key,\n    cast(to_char(m.message_date, 'YYYYMMDD') as integer) as date_key,\n    m.views,\n    m.forwards,\n    m.character_count,\n    m.word_count,\n    m.has_media\nfrom messages m\njoin channels c on m.channel_name = c.channel_name\n  );\n  ", "name": "SQLQuery", "pid": 14892, "thread": "Thread-5 (worker)", "ts": "2026-06-30T20:19:53.052124Z"}}
