{"data": {"conn_name": "model.medical_warehouse.dim_dates", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "bc258414f40885ae34f91fd226b1ec552c39d3bc25a1bd47478ffcc57495d5da", "node_finished_at": "", "node_name": "dim_dates", "node_path": "marts\\dim_dates.sql", "node_relation": {"alias": "dim_dates", "database": "medical_warehouse", "relation_name": "\"medical_warehouse\".\"public\".\"dim_dates\"", "schema": "public"}, "node_started_at": "2026-06-30T20:19:51.777058", "node_status": "executing", "resource_type": "model", "unique_id": "model.medical_warehouse.dim_dates"}, "sql": "/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.dim_dates\"} */\n\n  \n    \n\n  create  table \"medical_warehouse\".\"public\".\"dim_dates__dbt_tmp\"\n  \n  \n    as\n  \n  (\n    \n\nwith raw_dates as (\n    select distinct cast(message_date as date) as full_date\n    from \"medical_warehouse\".\"public\".\"stg_telegram_messages\"\n    where message_date is not null\n)\n\nselect\n    cast(to_char(full_date, 'YYYYMMDD') as integer) as date_key,\n    full_date,\n    extract(day from full_date) as day,\n    extract(month from full_date) as month,\n    extract(year from full_date) as year,\n    to_char(full_date, 'Day') as day_of_week\nfrom raw_dates\n  );\n  "}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "942a75ef-8dd8-4303-80a4-35c171aa9580", "level": "debug", "msg": "On model.medical_warehouse.dim_dates: /* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"medical_warehouse\", \"target_name\": \"dev\", \"node_id\": \"model.medical_warehouse.dim_dates\"} */\n\n  \n    \n\n  create  table \"medical_warehouse\".\"public\".\"dim_dates__dbt_tmp\"\n  \n  \n    as\n  \n  (\n    \n\nwith raw_dates as (\n    select distinct cast(message_date as date) as full_date\n    from \"medical_warehouse\".\"public\".\"stg_telegram_messages\"\n    where message_date is not null\n)\n\nselect\n    cast(to_char(full_date, 'YYYYMMDD') as integer) as date_key,\n    full_date,\n    extract(day from full_date) as day,\n    extract(month from full_date) as month,\n    extract(year from full_date) as year,\n    to_char(full_date, 'Day') as day_of_week\nfrom raw_dates\n  );\n  ", "name": "SQLQuery", "pid": 14892, "thread": "Thread-7 (worker)", "ts": "2026-06-30T20:19:52.349371Z"}}
